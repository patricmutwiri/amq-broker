# Copy this file to .env for local testing only, or export these values from your
# shell / secret manager in production. Never commit a populated .env file.

# Image selection
BROKER_IMAGE=apache/artemis:2.53.0
# Example Red Hat image:
# BROKER_IMAGE=registry.redhat.io/amq7/amq-broker-rhel8:7.13

# Naming
BROKER_CONTAINER_NAME=amq-broker
BROKER_HOSTNAME=amq-broker-1
BROKER_NETWORK_NAME=amq-broker-net

# Host exposure: keep loopback-only unless you have a deliberate firewall/proxy design.
BROKER_BIND_HOST=127.0.0.1
BROKER_CORE_PORT=61616
BROKER_MANAGEMENT_BIND_HOST=127.0.0.1
BROKER_MANAGEMENT_PORT=8161

# Storage and externalized config
BROKER_INSTANCE_DIR=./broker-instance
BROKER_ETC_OVERRIDE_DIR=./config/etc-override
BROKER_CERTS_DIR=./certs

# Admin credentials: replace before first boot.
ARTEMIS_USER=mutwiri
ARTEMIS_PASSWORD=31344baee9daa086c1c2138857083a739f965ab57fcd7c060788d6ab74707d65

# TLS placeholders for broker.xml/property substitution.
AMQ_TLS_ENABLED=false
AMQ_KEYSTORE_PATH=/etc/amq-certs/broker-keystore.p12
AMQ_KEYSTORE_PASSWORD=changeit
AMQ_TRUSTSTORE_PATH=/etc/amq-certs/broker-truststore.p12
AMQ_TRUSTSTORE_PASSWORD=changeit

# Optional Artemis broker creation flags. Add protocol, clustering, or journal args here.
ARTEMIS_EXTRA_ARGS=

# JVM tuning and runtime sizing
JAVA_ARGS_APPEND=-Xms1g -Xmx1g
BROKER_MEM_LIMIT=2g
BROKER_CPU_LIMIT=2.0
BROKER_PIDS_LIMIT=512
BROKER_NOFILE_SOFT_LIMIT=65536
BROKER_NOFILE_HARD_LIMIT=65536
BROKER_TMPFS_SIZE=64m

# Lifecycle and health checks
BROKER_STOP_GRACE_PERIOD=2m
BROKER_HEALTHCHECK_INTERVAL=30s
BROKER_HEALTHCHECK_TIMEOUT=5s
BROKER_HEALTHCHECK_RETRIES=5
BROKER_HEALTHCHECK_START_PERIOD=90s

# Operational timezone
TZ=UTC
